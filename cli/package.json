{
  "name": "cli",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "vizdiff": "dist/bin/vizdiff.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint --report-unused-disable-directives --parser-options=\"{tsconfigRootDir:null}\" .",
    "prepack": "yarn build",
    "prepublishOnly": "yarn lint && yarn test",
    "start": "VIZDIFF_API_URL=http://127.0.0.1:3001 ts-node src/bin/vizdiff.ts"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "0.21.2",
    "@types/node": "18.19.75",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "8.10.0",
    "eslint-plugin-es": "4.1.0",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jest": "27.9.0",
    "eslint-plugin-prettier": "4.2.1",
    "prettier": "2.8.8",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "commander": "10.0.1",
    "simple-git": "^3.27.0",
    "undici": "5.28.5",
    "zip-a-folder": "1.1.7"
  }
}
