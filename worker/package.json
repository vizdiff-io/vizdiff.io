{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn node --no-warnings --loader ts-node/esm --experimental-specifier-resolution=node src/worker.ts",
    "start": "yarn dev",
    "build": "tsc",
    "test": "TS_JEST_DISABLE_VER_CHECKER=true yarn node --no-warnings --experimental-vm-modules $(yarn bin jest)",
    "lint": "eslint --report-unused-disable-directives --parser-options=\"{tsconfigRootDir:null}\" ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.608.0",
    "dotenv-flow": "3.2.0",
    "pg": "8.10.0",
    "pg-listen": "1.7.0",
    "reflect-metadata": "0.1.13",
    "typeorm": "0.3.12"
  },
  "devDependencies": {
    "@types/dotenv-flow": "3.2.0",
    "@types/jest": "29.5.0",
    "@types/node": "18.15.11",
    "@types/pg": "8.6.6",
    "@types/supertest": "2.0.12",
    "eslint": "8.37.0",
    "jest": "27.5.1",
    "supertest": "6.3.3",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.1",
    "typescript": "5.0.4"
  }
}
