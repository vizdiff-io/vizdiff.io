{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn node --no-warnings --loader ts-node/esm --experimental-specifier-resolution=node src/worker.ts",
    "start": "yarn dev",
    "build": "tsc",
    "test": "TS_JEST_DISABLE_VER_CHECKER=true yarn node --no-warnings --experimental-vm-modules $(yarn bin jest)",
    "lint": "eslint --report-unused-disable-directives --parser-options=\"{tsconfigRootDir:null}\" ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.743.0",
    "@wdio/cli": "^9.8.0",
    "dotenv-flow": "3.3.0",
    "pg": "^8.13.1",
    "pg-listen": "^1.7.0",
    "pino": "8.21.0",
    "reflect-metadata": "0.1.14",
    "shared": "workspace:*",
    "tar": "^7.4.3",
    "typeorm": "^0.3.20",
    "webdriverio": "^9.8.0"
  },
  "devDependencies": {
    "@types/aws-sdk": "^2.7.4",
    "@types/dotenv-flow": "3.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^20.17.17",
    "@types/pg": "^8.11.11",
    "@types/supertest": "2.0.16",
    "@types/tar": "^6.1.13",
    "@wdio/globals": "^9.8.0",
    "@wdio/types": "^9.6.3",
    "eslint": "8.57.1",
    "jest": "27.5.1",
    "pino-pretty": "10.3.1",
    "supertest": "6.3.4",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "^5.7.3"
  }
}
