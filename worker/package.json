    "@octokit/rest": "^21.1.1",
    "@wdio/cli": "^9.12.7",
    "commander": "13.1.0",
    "dd-trace": "^5.51.0",
    "dotenv-flow": "4.1.0",
    "octokit": "4.1.3",
    "p-limit": "^6.2.0",
    "pg": "^8.15.6",
    "pg-listen": "^1.7.0",
    "pino": "9.11.0",
    "pino-pretty": "13.0.0",
    "pixelmatch": "7.1.0",
    "reflect-metadata": "0.2.2",
    "shared": "workspace:*",
    "stripe": "^18.1.0",
    "tar": "^7.4.3",
    "typeorm": "^0.3.23",
    "webdriverio": "^9.12.7"
  },
  "devDependencies": {
    "@types/dotenv-flow": "3.3.3",
    "@types/node": "^22.15.15",
    "@types/pg": "^8.15.0",
    "@types/supertest": "6.0.3",
    "@types/tar": "^6.1.13",
    "@wdio/globals": "^9.12.7",
    "@wdio/types": "^9.12.6",
    "esbuild": "^0.25.4",
    "eslint": "9.26.0",
    "supertest": "7.1.0",
    "ts-node": "10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
