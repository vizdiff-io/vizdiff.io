    "@customerio/cdp-analytics-node": "^0.3.9",
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^22.0.1",
    "@wdio/cli": "^9.23.3",
    "commander": "14.0.3",
    "dd-trace": "^5.85.0",
    "dotenv-flow": "4.1.0",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "pg-listen": "^1.7.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pixelmatch": "7.1.0",
    "reflect-metadata": "0.2.2",
    "shared": "workspace:*",
    "stripe": "^20.3.1",
    "tar": "^7.5.7",
    "typeorm": "^0.3.28",
    "webdriverio": "^9.23.3"
  },
  "devDependencies": {
    "@types/dotenv-flow": "3.3.3",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "6.0.3",
    "@types/tar": "^6.1.13",
    "@wdio/globals": "^9.23.0",
    "@wdio/types": "^9.23.3",
    "esbuild": "^0.27.3",
    "eslint": "9.26.0",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.1.3"
  }
