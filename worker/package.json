{
  "name": "worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn node --no-warnings --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/worker.ts",
    "start": "yarn dev",
    "build": "node build.js",
    "test": "yarn run vitest --run",
    "lint": "eslint src",
