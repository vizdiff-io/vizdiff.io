# Environment for the worker service (local development). See docs/CONFIGURATION.md for the full
# variable reference; the docker-compose stacks use the root .env instead.

APP_URL=http://localhost

# Enable posting commit statuses to GitHub/GitLab
# Defaults to true in production/staging, set to "true" for local testing
# ENABLE_VCS_STATUS=true

POSTGRES_USER=vizdiff
POSTGRES_PASS=vizdiff_password
POSTGRES_DATABASE=vizdiff
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-west-2
S3_BUCKET_NAME=vizdiff-artifacts
# Custom S3-compatible endpoint (e.g. a local MinIO); unset for real AWS S3.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# GitLab (per-host service tokens, same values as the api; see docs/CONFIGURATION.md)
# ---------------------------------------------------------------------------
GITLAB_HOSTS=[{"host":"https://gitlab.com","token":"glpat-...","rejectUnauthorized":true}]
# Default host used to resolve a token when a task carries no explicit host.
GITLAB_HOST=https://gitlab.com
# Single-host fallback (used only when GITLAB_HOSTS is unset):
# GITLAB_TOKEN=glpat-...
# GITLAB_REJECT_UNAUTHORIZED=true

# ---------------------------------------------------------------------------
# GitHub (disabled by default; required when GITHUB_ENABLED=true)
# ---------------------------------------------------------------------------
GITHUB_ENABLED=false
# GITHUB_APP_ID=your_github_app_id
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your_webhook_secret

WORKER_HEALTH_PORT=3003

# Stories rendered concurrently per ingest (each is one headless-Chrome session).
# WORKER_STORY_CONCURRENCY=1

# Upload sanity / safety limits (set any to 0 to disable that check)
# MAX_STORIES_PER_UPLOAD=1000
# MAX_TARBALL_FILES=50000
# MAX_EXTRACTED_BYTES=1073741824
# MAX_TARBALL_ENTRY_BYTES=268435456
# MAX_TARBALL_PATH_LENGTH=4096
# MAX_STORY_IDENTIFIER_LENGTH=2048
# --- Screenshot retention reaper (optional) ---
# Periodically deletes screenshot builds (DB rows + S3 objects) older than RETENTION_DAYS, while
# always keeping the most recent RETENTION_KEEP_LAST_N builds per project. Disabled by default
# because it permanently deletes data; set to "true" to enable.
# RETENTION_REAPER_ENABLED=true
# RETENTION_DAYS=90
# RETENTION_KEEP_LAST_N=10
# RETENTION_MAX_BUILDS_PER_SWEEP=200
# RETENTION_SWEEP_INTERVAL_MS=3600000
