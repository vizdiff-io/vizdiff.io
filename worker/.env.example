APP_URL=http://localhost

# Enable posting commit statuses to GitHub/GitLab
# Defaults to true in production/staging, set to "true" for local testing
# ENABLE_VCS_STATUS=true

POSTGRES_USER=vizdiff
POSTGRES_PASS=vizdiff_password
POSTGRES_DATABASE=vizdiff
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-west-2
S3_BUCKET_NAME=vizdiff-artifacts

GITHUB_APP_ID=your_github_app_id
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitLab settings (optional - for GitLab integration)
GITLAB_HOST=https://gitlab.com
# Set to false for self-hosted GitLab with self-signed certificates
GITLAB_REJECT_UNAUTHORIZED=true

STRIPE_SECRET_KEY=

CUSTOMER_IO_API_KEY=

SES_REGION=us-west-2
SES_FROM_EMAIL=alerts@example.com

WORKER_HEALTH_PORT=3003
