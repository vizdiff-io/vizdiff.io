{
  "name": "vizdiff",
  "version": "0.0.0",
  "private": true,
  "packageManager": "yarn@4.3.0",
  "workspaces": [
    "api",
    "cli",
    "frontend",
    "worker"
  ],
  "scripts": {
    "api": "yarn workspace api",
    "cli": "yarn workspace cli",
    "chromatic": "yarn workspace frontend run chromatic",
    "frontend": "yarn workspace frontend",
    "worker": "yarn workspace worker",
    "build:all": "yarn workspaces foreach --all -p run build",
    "test:all": "yarn workspaces foreach --all -p run test",
    "lint:all": "yarn workspaces foreach --all -p run lint"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "lerna": "^4.0.0",
    "prettier": "^3.3.3",
    "react-syntax-highlighter": "^15.5.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn lint:all && yarn dedupe"
    }
  },
  "dependencies": {
    "nodemon": "^3.1.4"
  }
}
