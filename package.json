{
  "name": "vizdiff",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "packageManager": "yarn@4.9.2",
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "api",
    "frontend",
    "shared",
    "worker"
  ],
  "scripts": {
    "api": "yarn workspace api",
    "frontend": "yarn workspace frontend",
    "worker": "yarn workspace worker",
    "build:all": "yarn workspace shared build && yarn workspaces foreach --all -p run build",
    "test:all": "yarn workspaces foreach --all -p run test",
    "lint:all": "yarn workspaces foreach --all -p run lint"
  },
  "packageExtensions": {
    "@storybook/nextjs": {
      "peerDependenciesMeta": {
        "webpack": {
          "optional": true
        }
      }
    },
    "@wdio/globals": {
      "peerDependenciesMeta": {
        "expect-webdriverio": {
          "optional": true
        }
      }
    }
  }
}
