    "@types/express": "4.17.17",
    "@types/jest": "29.5.0",
    "@types/jsonwebtoken": "9.0.1",
    "@types/node": "18.15.11",
    "@types/pg": "8.6.6",
    "@types/supertest": "2.0.12",
    "eslint": "8.37.0",
    "jest": "29.5.0",
    "pino-pretty": "^10.0.0",
