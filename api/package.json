{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn node --no-warnings --loader ts-node/esm --experimental-specifier-resolution=node src/index.ts",
    "start": "yarn dev",
    "build": "tsc",
    "test": "TS_JEST_DISABLE_VER_CHECKER=true yarn node --no-warnings --experimental-vm-modules $(yarn bin jest)",
    "lint": "eslint --report-unused-disable-directives --parser-options=\"{tsconfigRootDir:null}\" ."
  },
  "dependencies": {
    "cookie-parser": "1.4.6",
    "dotenv-flow": "3.2.0",
    "express": "4.18.2",
    "express-promise-router": "4.1.1",
    "jsonwebtoken": "9.0.0",
    "pg": "8.10.0",
    "pino": "8.11.0",
    "pino-http": "8.3.3",
    "reflect-metadata": "0.1.13",
    "typeorm": "0.3.12",
    "undici": "5.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.3",
    "@types/dotenv-flow": "3.2.0",
    "@types/express": "4.17.17",
    "@types/jest": "29.5.0",
    "@types/jsonwebtoken": "9.0.1",
    "@types/node": "18.15.11",
    "@types/pg": "8.6.6",
    "@types/supertest": "2.0.12",
    "eslint": "8.37.0",
    "jest": "29.5.0",
    "pino-http-print": "3.1.0",
    "pino-pretty": "10.0.0",
    "supertest": "6.3.3",
    "ts-jest": "29.1.0",
    "ts-node": "10.9.1",
    "typescript": "5.0.4"
  }
}
