{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn node --no-warnings --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node src/index.ts",
    "start": "yarn dev",
    "build": "node build.js",
    "test": "yarn run vitest --run",
    "lint": "eslint src",
    "typeorm": "node --no-warnings --loader ts-node/esm/transpile-only --experimental-specifier-resolution=node ./node_modules/typeorm/cli.js -d src/datasource.ts",
    "migration:generate": "yarn typeorm migration:generate",
    "migration:run": "yarn typeorm migration:run",
    "migration:revert": "yarn typeorm migration:revert"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1068.0",
    "@aws-sdk/lib-storage": "3.1073.0",
    "@aws-sdk/s3-request-presigner": "3.1073.0",
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/auth-app": "^8.1.2",
    "@octokit/rest": "^22.0.1",
    "body-parser": "2.3.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv-flow": "4.1.0",
    "express": "5.2.1",
    "express-promise-router": "4.1.1",
    "jsonwebtoken": "9.0.3",
    "openid-client": "^6.8.4",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "typeorm": "^1.1.0",
    "undici": "8.5.0",
    "uuidv7": "1.2.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/dotenv-flow": "3.3.3",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.0.0",
    "@types/pg": "8.20.0",
    "@types/pino-pretty": "^5.0.0",
    "@types/supertest": "7.2.0",
    "esbuild": "^0.28.1",
    "eslint": "9.39.5",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "4.1.9"
  }
}
