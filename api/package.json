    "@types/jest": "29.5.14",
    "@types/jsonwebtoken": "9.0.8",
    "@types/node": "18.19.75",
    "@types/pg": "8.11.11",
    "@types/supertest": "2.0.16",
    "eslint": "8.57.1",
    "jest": "27.5.1",
    "pino-http-print": "3.1.0",
    "pino-pretty": "10.3.1",
    "supertest": "6.3.4",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.7.3"
