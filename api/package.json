    "dotenv-flow": "3.3.0",
    "express": "4.21.2",
    "express-promise-router": "4.1.1",
    "jsonwebtoken": "9.0.2",
    "octokit": "3.2.1",
    "pg": "8.13.1",
    "pino": "8.21.0",
    "pino-http": "8.6.1",
    "reflect-metadata": "0.1.14",
    "typeorm": "0.3.20",
    "undici": "5.28.5",
    "uuidv7": "1.0.2"
