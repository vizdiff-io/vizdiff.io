# Environment for the api service (local development). See docs/CONFIGURATION.md for the full
# variable reference; the docker-compose stacks use the root .env instead.

APP_URL=http://localhost
PORT=3001
JWT_SECRET=change-me

# Enable posting commit statuses to GitHub/GitLab
# Defaults to true in production/staging, set to "true" for local testing
# ENABLE_VCS_STATUS=true

# ---------------------------------------------------------------------------
# Authentication (pluggable AuthProvider)
# AUTH_PROVIDER: "oidc" (default in production), "github", or "dev" (non-production
# fixed identity; no external IdP needed)
# ---------------------------------------------------------------------------
AUTH_PROVIDER=dev
DEV_AUTH_EMAIL=dev@vizdiff.local

# OIDC / Microsoft Entra (MSAL). Required when AUTH_PROVIDER=oidc.
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# OIDC_CLIENT_ID=your_oidc_client_id
# OIDC_CLIENT_SECRET=your_oidc_client_secret
# Defaults to ${APP_URL}/api/auth/callback when unset.
# OIDC_REDIRECT_URI=
# OIDC_SCOPES=openid profile email
# Set to false only for self-signed IdPs (development/testing).
# OIDC_REJECT_UNAUTHORIZED=true

POSTGRES_USER=vizdiff
POSTGRES_PASS=vizdiff_password
POSTGRES_DATABASE=vizdiff
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-west-2
S3_BUCKET_NAME=vizdiff-artifacts
# Custom S3-compatible endpoint (e.g. a local MinIO); unset for real AWS S3.
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true

# Presigned screenshot URL TTLs (seconds): interactive viewer / PR-MR comment images.
# IMAGE_URL_TTL_SECONDS=3600
# VCS_IMAGE_URL_TTL_SECONDS=604800

# ---------------------------------------------------------------------------
# GitLab (per-host service tokens; see docs/CONFIGURATION.md)
# ---------------------------------------------------------------------------
GITLAB_HOSTS=[{"host":"https://gitlab.com","token":"glpat-...","rejectUnauthorized":true}]
# Default host used to resolve a token when a payload/task carries no explicit host.
GITLAB_HOST=https://gitlab.com
# Single-host fallback (used only when GITLAB_HOSTS is unset):
# GITLAB_TOKEN=glpat-...
# GITLAB_REJECT_UNAUTHORIZED=true
# Global webhook secret (per-host webhookSecret in GITLAB_HOSTS takes precedence):
GITLAB_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# GitHub (disabled by default; required when GITHUB_ENABLED=true or AUTH_PROVIDER=github)
# ---------------------------------------------------------------------------
GITHUB_ENABLED=false
# GITHUB_APP_ID=your_github_app_id
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_WEBHOOK_SECRET=your_webhook_secret
